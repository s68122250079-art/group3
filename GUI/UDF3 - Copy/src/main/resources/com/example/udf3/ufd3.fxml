<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="185.0" prefWidth="744.0" style="-fx-background-color: #F0F0F0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.udf3.HelloController">
   <children>
      <Label layoutX="10.0" layoutY="25.0" text="Name:">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="Nametext" layoutX="50.0" layoutY="21.0" prefHeight="25.0" prefWidth="170.0" />

      <Label layoutX="235.0" layoutY="25.0" text="Address:">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="Addresstext" layoutX="295.0" layoutY="21.0" prefHeight="25.0" prefWidth="170.0" />

      <Label layoutX="480.0" layoutY="25.0" text="Phone Number:">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>
      <TextField fx:id="Phonetext" layoutX="575.0" layoutY="21.0" prefHeight="25.0" prefWidth="160.0" />

      <Button fx:id="Submittext" layoutX="180.0" layoutY="85.0" mnemonicParsing="false" onAction="#Submittext" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: linear-gradient(#fff, #bfd3e7); -fx-border-color: #aab5bf; -fx-background-radius: 2; -fx-border-radius: 2;" text="Submit">
         <font><Font size="13.0" />
         </font>
      </Button>

      <Label layoutX="275.0" layoutY="92.0" text="User Data:">
         <font><Font name="System Bold" size="12.0" /></font>
      </Label>

      <TextArea fx:id="Areatext" layoutX="338.0" layoutY="65.0" prefHeight="105.0" prefWidth="380.0" style="-fx-control-inner-background: white; -fx-font-family: 'Tahoma'; -fx-font-size: 13px; -fx-border-color: #A0A0A0;" />
   </children>
</AnchorPane>